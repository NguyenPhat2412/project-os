# Internal URL used only by the Next.js server proxy. The browser calls /api/v1.
PROJECT_OS_API_INTERNAL_URL=http://127.0.0.1:18080

# Optional comma-separated UI allow-list. API authorization is always enforced
# by Spring Security; this value must never be treated as an authorization source.
NEXT_PUBLIC_ADMIN_EMAILS=
ADMIN_EMAILS=

# Optional server-only AI provider secrets. Leave empty to disable AI actions.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
